#!/usr/bin/env bash
# @lat: [[tests#Failure signals]]
set -euo pipefail

export PATH="$HOME/.npm-global/bin:$PATH"
export LAT_LLM_KEY="${LAT_LLM_KEY:-unused}"

if ! command -v lat >/dev/null 2>&1; then
  echo "WARNING: lat not found, skipping lat checks. Run 'make lat-install' to set up."
  exit 0
fi

echo "Running lat check..."
lat check

echo "Running lat sync policy..."
bash scripts/check-lat-sync.sh --staged

if command -v pre-commit >/dev/null 2>&1; then
  if [ -f ".pre-commit-config.yaml" ]; then
    mapfile -t staged_files < <(git diff --cached --name-only)
    if [ "${#staged_files[@]}" -gt 0 ]; then
      echo "Running pre-commit hooks..."
      pre-commit run --hook-stage pre-commit --files "${staged_files[@]}"
    else
      echo "No staged files, skipping pre-commit hooks."
    fi
  else
    echo "WARNING: .pre-commit-config.yaml not found, skipping pre-commit hooks."
  fi
else
  echo "WARNING: pre-commit not found, skipping pre-commit hooks."
fi

echo "Pre-commit checks passed."
